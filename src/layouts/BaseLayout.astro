---
import Navbar from "@/components/layout/Navbar.astro";
import Footer from "@/components/layout/Footer.astro";
import "@/styles/global.css";

interface Props {
  title?: string;
  description?: string;
  noFooter?: boolean;
}

const siteName = "UAGRO";
const alternateSiteName = "MDO UAGro";
const organizationName = "Universidad Autónoma de Guerrero";
const fallbackSiteUrl = "https://mdo-alpha.vercel.app";
const iconPath = "/favicon.svg";
const ogImagePath = "/assets/logos/logo-mdo.webp";

const {
  title = "MDO UAGro | Maestría en Dirección de Organizaciones",
  description = "Sitio oficial de la Maestría en Dirección de Organizaciones de la UAGro.",
  noFooter = false,
} = Astro.props;

const currentPath = Astro.url.pathname;
const siteOrigin =
  Astro.site?.toString() ?? import.meta.env.PUBLIC_SITE_URL ?? fallbackSiteUrl;
const canonicalUrl = new URL(currentPath, siteOrigin).toString();
const homeUrl = new URL("/", siteOrigin).toString();
const ogImageUrl = new URL(ogImagePath, siteOrigin).toString();
const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  url: homeUrl,
  name: siteName,
  alternateName: alternateSiteName,
  inLanguage: "es-MX",
  publisher: {
    "@type": "Organization",
    name: organizationName,
    url: homeUrl,
    logo: new URL("/assets/logos/logo-uagro.webp", siteOrigin).toString(),
  },
};
const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: organizationName,
  alternateName: siteName,
  url: homeUrl,
  logo: new URL("/assets/logos/logo-uagro.webp", siteOrigin).toString(),
};
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow, max-image-preview:large" />
    <meta name="author" content="MDO UAGro" />
    <meta name="application-name" content={siteName} />
    <meta name="apple-mobile-web-app-title" content={siteName} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:locale" content="es_MX" />
    <meta property="og:image" content={ogImageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <link rel="icon" type="image/svg+xml" href={iconPath} />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:wght@600;700&display=swap"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:wght@600;700&display=swap" />
    </noscript>
    {currentPath === "/" && (
      <>
        <script is:inline type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
        <script is:inline type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
      </>
    )}
    <title>{title}</title>
  </head>
  <body>
    <div class="min-h-screen flex flex-col bg-background">
      <Navbar currentPath={currentPath} />
      <main class="flex-1 pt-24">
        <slot />
      </main>
      {!noFooter && <Footer />}
    </div>
  </body>
</html>
