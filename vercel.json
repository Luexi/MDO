{
    "cleanUrls": true,
    "trailingSlash": false,
    "headers": [
        {
            "source": "/(.*)",
            "headers": [
                {
                    "key": "X-Content-Type-Options",
                    "value": "nosniff"
                },
                {
                    "key": "X-Frame-Options",
                    "value": "DENY"
                },
                {
                    "key": "X-XSS-Protection",
                    "value": "1; mode=block"
                }
            ]
        }
    ],
    "routes": [
        {
            "src": "^/(favicon\\.svg|logo-.*\\.png|.*\\.(js|css|woff2?|svg|png|jpg|jpeg|webp|gif|ico))$",
            "headers": {
                "cache-control": "public, max-age=31536000, immutable"
            }
        }
    ]
}